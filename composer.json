{
    "name": "psc-acme/api-user",
    "description": "Package api-user for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ApiUser\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/yaml": "^7.0",
        "psr/log": "^3.0",
        "league/flysystem": "^3.0",
        "symfony/string": "^7.0",
        "brick/date-time": "^0.7.1",
        "psc-acme/gateway-auth": "^1.0",
        "psc-acme/renderer-auth": "^1.0",
        "psc-acme/compiler-auth": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan-symfony": "^1.0",
        "behat/behat": "^3.14"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}